{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Integration": {
    "CustomerSynchronization": {
      "Enabled": false,
      "PollingIntervalSeconds": 10,
      "BatchSize": 10,
      "MaxRetryAttempts": 3,
      "RetryDelaySeconds": 30,
      "ProcessingTimeoutMinutes": 5
    },
    "CustomerDiscovery": {
      "Enabled": false,
      "PollingIntervalSeconds": 10,
      "BatchSize": 100,
      "InitialLoadEnabled": false,
      "InitialLoadBatchSize": 100,
      "CheckpointOverlapSeconds": 5
    },
    "Database": {
      "RunMigrationsOnStartup": true
    },
    "Bitrix": {
      "WebhookBaseUrl": "https://bitrix24.local/rest/3/abc***xyz/",
      "TimeoutSeconds": 30,
      "IgnoreSslValidation": true,
      "ExternalCustomerIdField": "UF_CRM_WEBAPOLICE_CLIENTE_ID",
      "DocumentField": "UF_CRM_WEBAPOLICE_DOCUMENTO"
    },
    "WebApoliceDatabase": {
      "ConnectionString": ""
    },
    "Admin": {
      "ApiKey": "dev-admin-key"
    }
  }
}
